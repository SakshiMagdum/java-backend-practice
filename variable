public class variable {

    public static void main(String[] args){

        // variable = A reusable container for a value.
        //            A variable behaves as if it was the value it contains.

        // Primitive = simple value stored directly in memory (stack)
        // Reference = memory address (stack) that points to the (heap)

        //  Primitive           vs             Reference
        //   ---------                         ---------
        //   int (whole no., 32 bits)          string (a series of character)
        //   double (decimal, 64 bits)         array
        //   char (single character, 16 bits)  object
        //   boolean (true or false)
        //   float (decimal, 32 bits)
        //   long (long whole no., 64 bits)

        int age = 21;
        int year = 2026;

        System.out.println(age);
        System.out.println("This year is "+year);

        double price = 19.66;
        double cgpa = 8.04;
        double temperature = -12.9;

        System.out.println("$" + price);
        System.out.println(temperature);

        //char are enclosed in single quotes
        char grade = 'A';
        char symbol = '!';
        char currency = '$';

        System.out.println(symbol);

        boolean isStudent = true;
        boolean forSale = false;
        boolean isOnline = true;

        System.out.println(forSale);

        //Use of boolean

        if(isStudent){
            System.out.println("You are a student");
        }
        else{
            System.out.println("You are NOT a student");
        }

        float pi = 3.14159f;

        System.out.println(pi);
      
        //string are enclosed in double quotes
        String name = "Sakshi Magdum";
        String email = "xyz123@gmail.com";
        String car = "Ferrari";
        String color = "Red";

        System.out.println(name);

        //string concatenation
        System.out.println("My name is " + name);
        System.out.println("Your email is " + email);

        //combining multiple variable within a single print line statement
        System.out.println("Your choice is a " + color + " " + year + " " + car);
        System.out.println("The price is " + currency + price);

        if(forSale){
            System.out.println("There is a " + car + "for sale");
        }
        else{
            System.out.println("The " + car + " is not for sale");
        }
 
    }
}
